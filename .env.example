# Mapbox tokens for turn-by-turn navigation.
# Copy this file to `.env.local` and paste your real tokens. Do NOT commit `.env*`.

# Public access token — starts with `pk.`. Exposed to the JS bundle.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.YOUR_PUBLIC_TOKEN_HERE

# Secret SDK download token — starts with `sk.`. Used at native build time
# (iOS CocoaPods + Android Gradle) to download Mapbox's paid SDKs. Never
# committed, never shipped — only present on your dev machine and in EAS
# secrets for CI builds.
MAPBOX_DOWNLOADS_TOKEN=sk.YOUR_DOWNLOADS_TOKEN_HERE
